# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8787

# API Secrets (set via wrangler secret)
# JWT_SECRET=your_jwt_secret_min_32_chars
# RESEND_API_KEY=your_resend_api_key
# CAPTCHA_SECRET=your_turnstile_secret
